# ── Kafka (local WSL2 broker) ─────────────────────────────────────────────────
# Start Kafka: kafka-server-start.sh ~/kafka/config/kraft/server.properties
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TRANSACTIONS_TOPIC=raw-transactions
KAFKA_RESULTS_TOPIC=fraud-results
KAFKA_CONSUMER_GROUP=fraud-detection-group

# ── ML Thresholds ─────────────────────────────────────────────────────────────
# FRAUD_THRESHOLD: XGBoost probability above this = fraud
# Lower = more transactions flagged, more fraud caught, more false alarms
FRAUD_THRESHOLD=0.85

# ANOMALY_THRESHOLD: Isolation Forest score below this = anomalous
# More negative = stricter anomaly detection
ANOMALY_THRESHOLD=-0.1

# ── AML (Anti-Money Laundering) ───────────────────────────────────────────────
# Currency Transaction Report threshold (Nigeria: ₦5,000,000)
# Transactions at or above this value require automatic CTR filing
AML_CTR_THRESHOLD=5000000

# ── LLM (AI Investigation Agent) ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development